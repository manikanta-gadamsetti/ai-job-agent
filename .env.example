JOB_AGENT_DB_PATH=./job_agent.sqlite
ARTIFACTS_DIR=./out
BASE_RESUME_PATH=./data/base_resume.md

# Optional LLM tailoring (OpenAI-compatible)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Preferences (defaults exist in code)
